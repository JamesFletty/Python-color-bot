{
  "product_line": "DIA Richesse",
  "brand": "L'Or\u00e9al Professionnel",
  "type": "Demi-Permanent Haircolor",
  "rules": {
    "line_name": "DIA Richesse",
    "technology": "Advanced Alkaline Technology",
    "type": "Rich demi-permanent cr\u00e8me haircolor without ammonia",
    "key_benefits": [
      "Coverage up to 70% white hair",
      "Rich and deep reflects. Exceptional softness.",
      "Up to 1.5 levels of lift",
      "Ideal for natural or color-treated hair"
    ],
    "color_process": {
      "before": "Natural or color-treated hair",
      "during": "Colorants penetrate and bond themselves inside the hair fiber. The colorants develop in harmony with the Diactivateur used.",
      "after": "Hair cuticle is closed. Ultra-shiny hair, colored with a rich and deep shade. Result intensity varies according to the Diactivateur chosen. Visible tones, even on dark bases. Exceptional softness."
    },
    "preparation": {
      "ratio": "1:1.5",
      "mixing": "Measure 2.6 oz. of Diactivateur (6-vol/1.8%, 9-vol/2.7%, or 15-vol/4.5% depending on desired intensity). Add 1 tube (1.7 oz.) of DIA Richesse haircolor. Mix until smooth, creamy texture."
    },
    "application": {
      "on": "Dry unwashed hair",
      "method": "Apply with brush or plastic bottle on re-growth, mid-lengths and ends",
      "development_time": "2 to 20 minutes",
      "aftercare": "Carefully emulsify, rinse thoroughly and finish with specific post-haircolor shampoo"
    },
    "service_guidelines": {
      "virgin_application": "9- or 15-vol Diactivateur, 20 min",
      "refreshing_mid_lengths_ends": "6-vol Diactivateur, 5-10 min",
      "pre_coloration": "N/A",
      "covering_up_to_30_white": "9-vol Diactivateur, 20 min",
      "covering_up_to_70_white": "15-vol Diactivateur, 20 min",
      "toning_lightened_hair": "6-vol Diactivateur, 2-10 min",
      "post_perm": "6-vol Diactivateur, 5-10 min",
      "post_smoothing": "6-vol Diactivateur, 5-10 min",
      "post_straightening": "6-vol Diactivateur, 5-10 min"
    }
  },
