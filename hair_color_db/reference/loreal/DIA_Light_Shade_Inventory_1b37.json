{
  "product_line": "DIA Light",
  "brand": "L'Or\u00e9al Professionnel",
  "type": "Demi-Permanent Haircolor",
  "rules": {
    "line_name": "DIA Light",
    "technology": "Gentle Acid Technology",
    "type": "Luminous demi-permanent gel-cr\u00e8me haircolor without ammonia",
    "key_benefits": [
      "Color personalization and correction made easy, quick and predictable",
      "Luminous tones, vinyl shine, exceptionally even color",
      "Zero lift",
      "Intense care for the hair",
      "Ideal for color-treated or sensitized hair"
    ],
    "color_process": {
      "before": "Faded color-treated or sensitized hair fiber. The alkaline agent is neutralized during mixing.",
      "during": "The hair fiber swells slightly due to a water-based environment with an acidic pH. Colorants penetrate and bond themselves inside the hair fiber. The colorants develop in harmony to the hair's natural tones.",
      "after": "Hair cuticle is closed and the hair fiber benefits from a resurfacing effect. Hair reveals a vinyl-like shine and a luminous tone. Intense haircare-like result."
    },
    "preparation": {
      "ratio": "1:1.5",
      "mixing": "Measure 2.6 oz. of Diactivateur (6-vol/1.8%, 9-vol/2.7%, or 15-vol/4.5% depending on desired intensity). Add 1 tube (1.7 oz.) of DIA Light haircolor. Mix until smooth, creamy texture."
    },
    "application": {
      "on": "Dry unwashed hair",
      "method": "Apply with brush or plastic bottle on re-growth, mid-lengths and ends",
      "development_time": "2 to 20 minutes",
      "aftercare": "Carefully emulsify, rinse thoroughly and finish with specific post-haircolor shampoo"
    },
    "service_guidelines": {
      "virgin_application": "n/a",
      "refreshing_mid_lengths_ends": "6-vol Diactivateur, up to 20 min",
      "pre_coloration": "6-vol Diactivateur, 20 min",
      "covering_up_to_30_white": "n/a",
      "covering_up_to_70_white": "n/a",
      "toning_lightened_hair": "6-vol Diactivateur, 2-10 min",
      "post_perm": "6-vol Diactivateur, 5-10 min",
      "post_smoothing": "6-vol Diactivateur, 5-10 min",
      "post_straightening": "6-vol Diactivateur, 5-10 min"
    }
  },
