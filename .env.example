# Copy to .env and adjust for local PostgreSQL (see docker-compose.yml).
DATABASE_URL=postgresql+psycopg2://haircolor:haircolor@localhost:5432/haircolor

# Runtime
# ENVIRONMENT=development
# ENGINE_BACKEND=sqlite
# ENGINE_BACKEND=postgres
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8000
# ENABLE_OPENAPI_DOCS=true

# AI layer (optional — only needed for /api/ai/* routes)
# With no cloud credentials in development, offline mock AI is used automatically.
# In production, mock is disabled unless AI_ALLOW_MOCK=1.
# AI_PROVIDER=mock

# Azure OpenAI (recommended for production)
# Create deployments in Azure AI Foundry / Azure OpenAI Studio, e.g. gpt-4o-mini + gpt-4o.
#AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
#AZURE_OPENAI_API_KEY=your-azure-openai-key
#AZURE_OPENAI_API_VERSION=2024-10-21
#AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
#AZURE_OPENAI_TRANSLATE_DEPLOYMENT=gpt-4o

# Direct OpenAI (alternative)
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Amazon Bedrock via OpenAI-compatible API (uses AWS credits)
# 1) Bedrock console → Model access → enable your model (e.g. nvidia.nemotron-super-3-120b)
# 2) Bedrock console → API keys → create key (never commit or paste in chat)
# 3) Mantle models use https://bedrock-mantle.<region>.api.aws/v1 (not bedrock-runtime)
# NOTE: Never put a real key in this tracked template. Set these as project
#       environment variables (they are loaded from .env.development.local /
#       .env.local at runtime), not here.
# AI_PROVIDER=openai
# OPENAI_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
# OPENAI_API_KEY=your-bedrock-api-key
# OPENAI_CHAT_MODEL=nvidia.nemotron-super-3-120b
# OPENAI_TRANSLATE_MODEL=nvidia.nemotron-super-3-120b
# Other mantle models (same base URL pattern):
# OPENAI_CHAT_MODEL=openai.gpt-oss-120b
# OPENAI_TRANSLATE_MODEL=openai.gpt-oss-120b
# OPENAI_CHAT_MODEL=moonshotai.kimi-k2.5
# OPENAI_TRANSLATE_MODEL=moonshotai.kimi-k2.5
# OPENAI_CHAT_MODEL=openai.gpt-5.4
# OPENAI_TRANSLATE_MODEL=openai.gpt-5.5
# Legacy bedrock-runtime OpenAI-compatible (auto-normalized to /openai/v1):
# OPENAI_BASE_URL=https://bedrock-runtime.us-east-1.amazonaws.com/compatible-apis/openai/v1

# xAI Grok (alternative)
# XAI_API_KEY=xai-...

# v2 LLM (single provider — OpenAI SDK + optional base URL override)
# LLM_API_KEY=your-key-here
# LLM_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/v1
# LLM_CHAT_MODEL=gpt-4o-mini
# LLM_TRANSLATE_MODEL=gpt-4o-mini
