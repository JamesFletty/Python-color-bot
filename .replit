modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["python_openai_ai_integrations:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m uvicorn api.main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "-m", "uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "5000"]

[userenv]

[userenv.shared]
OPENAI_BASE_URL = "https://bedrock-mantle.us-east-1.api.aws/v1"
OPENAI_CHAT_MODEL = "nvidia.nemotron-super-3-120b"
OPENAI_TRANSLATE_MODEL = "nvidia.nemotron-super-3-120b"
AI_PROVIDER = "openai"
